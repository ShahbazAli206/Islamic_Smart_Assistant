# ──────────────────────────────────────────────────────────────────────────────
# Community Audio Uploads (Supabase) — required for uploads to be visible
# to ALL users across web and desktop app.
#
# Setup (free, takes ~5 minutes):
#
# 1. Go to https://supabase.com → New Project
#
# 2. In the Supabase SQL Editor, run this SQL:
#
#    CREATE TABLE community_uploads (
#      id          text PRIMARY KEY,
#      name        text NOT NULL,
#      audio_type  text NOT NULL DEFAULT 'azan',
#      public_url  text NOT NULL,
#      duration_sec numeric NOT NULL DEFAULT 0,
#      created_at  timestamptz DEFAULT now()
#    );
#    ALTER TABLE community_uploads ENABLE ROW LEVEL SECURITY;
#    CREATE POLICY "public read"   ON community_uploads FOR SELECT USING (true);
#    CREATE POLICY "public insert" ON community_uploads FOR INSERT WITH CHECK (true);
#    CREATE POLICY "public delete" ON community_uploads FOR DELETE USING (true);
#
# 3. Go to Storage → New Bucket
#    Name: azan-audio
#    ✅ Public bucket  (tick the checkbox)
#
# 4. Copy your project URL and anon key from:
#    Project Settings → API → Project URL & anon/public key
#
# 5. Rename THIS file to .env.local and fill in the values below
#
# 6. Rebuild the app (npm run build in /web, then rebuild the installer)
# ──────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
# Use the LEGACY anon key (eyJ... JWT format) from:
# Supabase Dashboard → Project Settings → API Keys → "Legacy anon, service_role API keys" tab → anon/public row
# The new sb_publishable_* key does NOT work with Supabase REST API (returns 401).
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_LEGACY_ANON_JWT_KEY_HERE

# ──────────────────────────────────────────────────────────────────────────────
# Quran Foundation API credentials — used ONLY by the one-time, manually-run
# script scripts/ingest-mushaf-indopak16.ts. The deployed app never reads these
# and never calls the Quran Foundation API at runtime; it reads the static JSON
# that script writes to public/data/mushaf-indopak16/.
#
# Get free credentials by registering at:
# https://api-docs.quran.foundation/request-access/
# ──────────────────────────────────────────────────────────────────────────────
QF_CLIENT_ID=
QF_CLIENT_SECRET=
