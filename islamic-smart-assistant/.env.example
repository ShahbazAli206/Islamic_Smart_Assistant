# --- Backend ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/islamic_assistant

# Redis (used for BullMQ + WebSocket adapter + cache)
REDIS_URL=redis://localhost:6379

# JWT
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Object storage (S3-compatible: AWS S3 or Cloudflare R2)
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=islamic-assistant-audio
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Push notifications
FCM_SERVICE_ACCOUNT_JSON_PATH=./keys/fcm-service-account.json
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_PATH=./keys/apns-key.p8
APNS_BUNDLE_ID=app.islamicassistant.mobile

# OAuth (optional)
GOOGLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_KEY_ID=

# IP geolocation fallback (any provider with a free tier)
IP_GEOLOCATION_API_KEY=

# --- Web Dashboard ---
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4000/v1/sync

# Self-generated Quran translation audio (Bengali/Hindi) hosted on Supabase
# Storage. Produced once by scripts/generate_translation_audio.py. Set
# NEXT_PUBLIC_TTS_TRANSLATION_LANGS to the comma-list of folders you've uploaded
# (e.g. "bn,hi") to switch those languages from text-only to audio playback.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_TTS_TRANSLATION_LANGS=
# NEXT_PUBLIC_TTS_BUCKET=quran-audio

# Used only by scripts/generate_translation_audio.py (local, one-time). The
# service_role key can write to Storage — keep it secret, never expose to browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=quran-audio

# --- Mobile ---
# (set in mobile/.env — see mobile/.env.example)
