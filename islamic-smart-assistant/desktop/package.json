{
  "name": "islamic-assistant-desktop",
  "version": "1.0.0",
  "description": "Islamic Assistant — Prayer times, Quran, Azan, Qibla",
  "author": "Islamic Assistant",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:*\"",
    "dev:web": "npm --prefix ../web run dev",
    "dev:electron": "wait-on http://localhost:3000 && electron .",
    "prebuild": "cd ../web && npm run build",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "app.islamicassistant.desktop",
    "productName": "Islamic Assistant",
    "files": [
      "electron/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../web/.next/standalone",
        "to": "web/.next/standalone",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../web/.next/static",
        "to": "web/.next/standalone/.next/static",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../web/public",
        "to": "web/.next/standalone/public",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "sign": null,
      "signingHashAlgorithms": null,
      "certificateFile": null,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.lifestyle",
      "identity": null
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network"
    }
  },
  "dependencies": {
    "bonjour-service": "^1.4.1",
    "castv2-client": "^1.2.0",
    "node-ssdp": "^4.0.1",
    "upnp-mediarenderer-client": "^1.4.0"
  }
}
