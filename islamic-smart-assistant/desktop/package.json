{
  "name": "islamic-assistant-desktop",
  "version": "1.3.4",
  "description": "Islamic Assistant — Prayer times, Quran, Azan, Qibla",
  "author": "Islamic Assistant",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:*\"",
    "dev:web": "npm --prefix ../web run dev",
    "dev:electron": "wait-on http://localhost:3000 && electron .",
    "prebuild": "cd ../web && npm run build",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:win:x64": "electron-builder --win --x64",
    "build:win:ia32": "electron-builder --win --ia32",
    "build:win:arm64": "electron-builder --win --arm64",
    "build:win:all": "electron-builder --win --x64 --ia32 --arm64",
    "build:win:universal": "node scripts/build-universal-win.js",
    "release": "electron-builder --win --x64 --publish always",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "app.islamicassistant.desktop",
    "productName": "Islamic Assistant",
    "copyright": "Copyright © 2024 Islamic Assistant",
    "artifactName": "${productName} Setup ${version} ${arch}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "ShahbazAli206",
        "repo": "Islamic_Assistant_Audio"
      }
    ],
    "files": [
      "electron/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../web/.next/standalone",
        "to": "web/.next/standalone",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../web/.next/standalone/node_modules",
        "to": "web/.next/standalone/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../web/.next/static",
        "to": "web/.next/standalone/.next/static",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../web/public",
        "to": "web/.next/standalone/public",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Islamic-Assistant-Setup-${version}.${ext}",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Islamic Assistant",
      "menuCategory": "Islamic Assistant",
      "runAfterFinish": true,
      "include": "installer.nsh"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.lifestyle",
      "identity": null
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network"
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.18",
    "bonjour-service": "^1.4.1",
    "electron-updater": "^6.3.9",
    "castv2-client": "0.0.8",
    "node-ssdp": "^4.0.0",
    "upnp-mediarenderer-client": "^1.4.0"
  }
}
